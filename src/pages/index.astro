---
import Base from "../layouts/Base.astro";
import Button from "../components/Button.astro";
import Card from "../components/Card.astro";
import { Image } from "astro:assets";
import Testimonial from "../components/Testimonial.astro";
import LogoField from "../components/LogoField.astro";

// Project images
import books from "../assets/books.png";
import kiteworkscard from "../assets/kiteworkscard.png";
import openbankingcard from "../assets/openbankingcard.png";
import lpc from "../assets/lpc.png";
import fastpencilcard from "../assets/fastpencilcard.png";
import juice from "../assets/juice.png";
import whale_shirts from "../assets/whale_shirts.png";
import jackThumb from "../assets/09_people.BUrkml1d.webp";
import coastalcard from "../assets/coastalcard.png";
import linguidcard from "../assets/linguidcard.png";
import martinellisThumb from "../assets/martinellis-thumb.webp";
import walksantacruzThumb from "../assets/walksantacruz-thumb.png";

// Profile photo
import newProfilePic from "../assets/My-biopic_new-profile-pic.jpg";

// Testimonial photos
import abishek from "../assets/abishek.png";
import diana from "../assets/diana.jpg";
import bruce from "../assets/bruce.jpg";
import jennine from "../assets/jennine.jpg";
---

<Base title="Matthew O&rsquo;Leary - Production-Focused Designer">

  <!-- HERO SECTION -->
  <section class="px-4 2xl:px-0 py-16 md:py-24">
    <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12 max-w-5xl mx-auto">
      <div class="w-48 md:w-64 flex-shrink-0 animate-on-scroll">
        <Image
          src={newProfilePic}
          alt="Matthew O&rsquo;Leary"
          class="rounded-full ring-4 ring-white shadow-xl"
        />
      </div>
      <div class="text-center md:text-left animate-on-scroll">
        <h1 class="font-heading text-5xl md:text-6xl xl:text-7xl font-bold mb-6 gradient-text">
          Design & Production
        </h1>
        <p class="text-xl md:text-2xl text-stone-600 leading-relaxed">
          20+ years as a creative producer—bringing designs to life across web, print, packaging, and everything in between.
        </p>
      </div>
    </div>
  </section>

  <!-- SKILLS SECTION -->
  <section class="px-4 2xl:px-0 py-16 md:py-20 bg-stone-100/50">
    <div class="max-w-6xl mx-auto">
      <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 text-center animate-on-scroll">What I Do</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-12 animate-on-scroll">Core Capabilities</h2>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-white/80 backdrop-blur-sm border border-white/50 rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow animate-on-scroll">
          <div class="w-12 h-12 bg-violet-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-violet-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/>
            </svg>
          </div>
          <h3 class="font-heading font-semibold text-xl mb-2">Design Adaptation</h3>
          <p class="text-stone-600">Taking any design and adapting it for production—print collateral, packaging, large-format signage, or web-ready digital assets.</p>
        </div>

        <div class="bg-white/80 backdrop-blur-sm border border-white/50 rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow animate-on-scroll">
          <div class="w-12 h-12 bg-violet-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-violet-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
          </div>
          <h3 class="font-heading font-semibold text-xl mb-2">Web & UI Design</h3>
          <p class="text-stone-600">Designing responsive websites and web applications from concept to launch. Experience with SaaS products, e-commerce, and content-driven sites.</p>
        </div>

        <div class="bg-white/80 backdrop-blur-sm border border-white/50 rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow animate-on-scroll">
          <div class="w-12 h-12 bg-violet-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-violet-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <h3 class="font-heading font-semibold text-xl mb-2">UX & Product Design</h3>
          <p class="text-stone-600">Creating intuitive interfaces for complex web applications. Background includes fintech dashboards, collaboration tools, and enterprise software.</p>
        </div>

        <div class="bg-white/80 backdrop-blur-sm border border-white/50 rounded-xl p-6 shadow-md hover:shadow-lg transition-shadow animate-on-scroll">
          <div class="w-12 h-12 bg-violet-100 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-violet-800" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
          </div>
          <h3 class="font-heading font-semibold text-xl mb-2">Digital Marketing</h3>
          <p class="text-stone-600">Designing for email campaigns, social media, and landing pages. Strong understanding of conversion-focused design and user engagement.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WORK GRID SECTION -->
  <section class="px-4 2xl:px-0 py-16 md:py-20">
    <div class="max-w-7xl mx-auto">
      <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 text-center animate-on-scroll">Portfolio</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-12 animate-on-scroll">Selected Work</h2>

      <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-2">
        <Card img={walksantacruzThumb} alt="Walk Santa Cruz" title="Walk Santa Cruz" link="/work/walksantacruz" />
        <Card img={linguidcard} alt="Linguid" title="Linguid" link="/work/linguid" />
        <Card img={jackThumb} alt="Jack Pitts Photography" title="Jack Pitts Photography" link="/work/jack" />
        <Card img={coastalcard} alt="Coastal Nature Guides" title="Coastal Nature Guides" link="/work/coastal" />
        <Card img={books} alt="Book Covers" title="Book Covers" link="/work/books" />
        <Card img={kiteworkscard} alt="Kiteworks Web App" title="Kiteworks Web App" link="/work/kiteworks" />
        <Card img={openbankingcard} alt="Open Banking" title="Open Banking" link="/work/openbanking" />
        <Card img={lpc} alt="Live Price Check" title="Live Price Check" link="/work/livepricecheck" />
        <Card img={fastpencilcard} alt="FastPencil" title="FastPencil" link="/work/fastpencil" />
        <Card img={juice} alt="The Juice Magazine" title="The Juice Magazine" link="/work/juice" />
        <Card img={whale_shirts} alt="Santa Cruz Whale Watching" title="Santa Cruz Whale Watching" link="/work/whalewatching" />
        <Card img={martinellisThumb} alt="Production Design" title="Production Design" link="/work/production-design" />
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS SECTION -->
  <section class="px-4 2xl:px-0 py-16 md:py-20 bg-stone-100/50">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 text-center animate-on-scroll">Testimonials</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-12 animate-on-scroll">What People Say</h2>

      <Testimonial
        quote="Matt is an incredibly designer who works hard to identify/solve for customers&rsquo; pain points. His designs for critical and heavily used functionality were well received and had a lasting impact on the product adoption."
        img={abishek}
        alt="Abishek Aurora"
        person="Abishek Aurora"
        title="Director of Product"
        company="Credit Karma"
      />

      <Testimonial
        quote="I worked with Matt on a variety of packaging and communication material design and production projects. Matt is very knowledgeable as well as personable, guiding the process to ensure expected creative outcomes."
        img={diana}
        alt="Diana McClean"
        person="Diana (DeVincenzi) McClean"
        title="Director of Marketing and Communications"
        company="Mission Produce"
      />

      <Testimonial
        quote="Matt is a very creative individual. His knowledge of design as well as production techniques and crafts is invaluable and enables him to participate from start to finish on every project. From book covers to website and page design, Matt&rsquo;s creative sense is remarkable and invaluable."
        img={bruce}
        alt="Bruce Butterfield"
        person="Bruce Butterfield"
        title="CEO and Founder"
        company="The Wittfield Group"
      />

      <Testimonial
        quote="I find it refreshing to work with someone who knows how to tackle big projects while staying calm, focused and creative all while delivering outstanding work."
        img={jennine}
        alt="Jennine Dureau"
        person="Jennine Dureau"
        title="Marketing Manager"
        company="TurboTax"
      />
    </div>
  </section>

  <!-- BRANDS SECTION -->
  <section class="px-4 2xl:px-0 py-16 md:py-20">
    <div class="max-w-5xl mx-auto">
      <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 text-center animate-on-scroll">Experience</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-12 animate-on-scroll">Brands I&rsquo;ve Worked With</h2>
      <div class="animate-on-scroll">
        <LogoField />
      </div>
    </div>
  </section>

  <!-- CONTACT SECTION -->
  <section class="px-4 2xl:px-0 py-16 md:py-20 bg-stone-100/50">
    <div class="max-w-2xl mx-auto text-center">
      <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 animate-on-scroll">Get in Touch</p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold mb-6 animate-on-scroll">Let&rsquo;s Work Together</h2>
      <p class="text-xl text-stone-600 mb-8 animate-on-scroll">
        Ready to start your next project? I&rsquo;d love to hear from you.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-on-scroll">
        <a href="/contact" class="w-full sm:w-auto">
          <Button text="Get in touch" class="w-full" />
        </a>
        <a href="tel:8312752566" class="w-full sm:w-auto inline-flex items-center justify-center px-8 py-3 text-lg font-semibold text-violet-800 hover:text-violet-900 transition-colors">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          831-275-2566
        </a>
      </div>
    </div>
  </section>

</Base>
