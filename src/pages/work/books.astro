---
import Base from "../../layouts/Base.astro";
import ThinnerContent from "../../components/ThinnerContent.astro";
import { Image } from "astro:assets";
import Back from "../../components/Back.astro";
import healer from "../../assets/healer.png";
import third from "../../assets/third.jpg";
import travel from "../../assets/travel.jpg";
import miles from "../../assets/miles.jpg";
import conversations from "../../assets/conversations.jpg";
import gullibills from "../../assets/gullibills.jpg";
import homework from "../../assets/homework.jpg";
import kills from "../../assets/kills.jpg";
import prego from "../../assets/prego.jpg";
import shakespeare from "../../assets/shakespeare.jpg";
import till from "../../assets/till.jpg";
import together from "../../assets/together.jpg";
import torque from "../../assets/torque.jpg";

const title = "Book Design & Production";

const books = [
  { src: torque, alt: "Torque" },
  { src: miles, alt: "500 Miles" },
  { src: together, alt: "Together" },
  { src: till, alt: "Till" },
  { src: shakespeare, alt: "Shakespeare" },
  { src: homework, alt: "Homework" },
  { src: gullibills, alt: "Gullibills" },
  { src: conversations, alt: "Conversations" },
  { src: healer, alt: "Healer" },
  { src: travel, alt: "Travel to Tomorrow" },
  { src: third, alt: "Third Times a Charm" },
  { src: prego, alt: "Prego" },
  { src: kills, alt: "Kills" },
];
---

<Base title={title}>
  <ThinnerContent>
    <h1 class="font-heading font-bold text-4xl sm:text-5xl my-8">{title}</h1>
    <p class="mb-4 max-w-4xl">
      While at FastPencil — a self-publishing platform — I worked with authors
      across the full book production pipeline: cover design, interior
      typesetting, and final print-ready file delivery for Amazon KDP, Ingram
      Spark, and other POD (print-on-demand) and distribution outlets. Every
      file had to meet exact platform specifications: correct trim size, bleed,
      margin safety zones, embedded fonts, color profile, and compliant PDF
      export settings.
    </p>
    <p class="mb-4 max-w-4xl">
      <strong>I work in three modes depending on where your project is:</strong>
    </p>
    <ul class="mb-4 max-w-4xl list-disc list-inside space-y-2 text-stone-700">
      <li>
        <strong>Design from scratch</strong> — full cover concept and interior
        layout built in InDesign from the ground up, starting from your
        manuscript or content brief.
      </li>
      <li>
        <strong>Format from a Word document</strong> — I take your manuscript
        out of Word and flow it into a properly structured InDesign layout with
        correct typesetting, styles, margins, and gutter — ready for print
        submission.
      </li>
      <li>
        <strong>Preflight &amp; conform existing files</strong> — if you already
        have a design or a nearly-finished PDF, I bring it into full compliance:
        resolving trim, bleed, margin, font-embedding, and color issues so it
        passes KDP and Ingram Spark submission without rejection.
      </li>
    </ul>
    <p class="mb-4 max-w-4xl">
      <strong>Cover design &amp; full cover spreads</strong> — I design front
      covers from scratch and build complete cover spreads (front, spine, back)
      sized to exact platform specifications. Spine width is calculated from
      page count and paper stock using the KDP cover calculator. I deliver a
      press-ready PDF and source files in InDesign and Illustrator.
    </p>
    <p class="mb-4 max-w-4xl">
      <strong>Interior formatting &amp; typesetting</strong> — full interior
      production in InDesign: margins, gutter, bleed, widow and orphan control,
      image placement and alignment, consistent chapter styles, and
      platform-compliant PDF export for both print and digital editions. I
      also troubleshoot and correct existing PDFs in Acrobat Pro when a full
      re-layout isn&rsquo;t needed.
    </p>
    <p class="mb-8 font-semibold">
      <a
        href="mailto:matt@mattoleary.design?subject=Book project"
        class="text-violet-800 hover:text-violet-900 hover:underline"
        >Reach out</a
      > to chat about your next book project.
    </p>

    <div id="gallery" class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
      {books.map((book) => (
        <a
          href={book.src.src}
          data-pswp-width={book.src.width}
          data-pswp-height={book.src.height}
          target="_blank"
          class="block cursor-zoom-in transition-transform duration-300 hover:scale-105"
        >
          <Image src={book.src} alt={book.alt} class="w-full rounded-lg shadow-md" />
        </a>
      ))}
    </div>
  </ThinnerContent>
  <Back next="/work/coastal" />
</Base>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@5.4.3/dist/photoswipe.min.css" />


<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const initLightbox = () => {
    const lightbox = new PhotoSwipeLightbox({
      gallery: '#gallery',
      children: 'a',
      pswpModule: () => import('photoswipe'),
    });
    lightbox.init();
  };

  // Init on page load
  initLightbox();

  // Re-init on Astro page transitions
  document.addEventListener('astro:page-load', initLightbox);
</script>
