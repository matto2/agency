---
import Base from "../../layouts/Base.astro";
import ThinnerContent from "../../components/ThinnerContent.astro";
import { Image } from "astro:assets";
import Back from "../../components/Back.astro";
import healer from "../../assets/healer.png";
import third from "../../assets/third.jpg";
import travel from "../../assets/travel.jpg";
import miles from "../../assets/miles.jpg";
import conversations from "../../assets/conversations.jpg";
import gullibills from "../../assets/gullibills.jpg";
import homework from "../../assets/homework.jpg";
import kills from "../../assets/kills.jpg";
import prego from "../../assets/prego.jpg";
import shakespeare from "../../assets/shakespeare.jpg";
import till from "../../assets/till.jpg";
import together from "../../assets/together.jpg";
import torque from "../../assets/torque.jpg";

const title = "Book Design";

const books = [
  { src: torque, alt: "Torque" },
  { src: miles, alt: "500 Miles" },
  { src: together, alt: "Together" },
  { src: till, alt: "Till" },
  { src: shakespeare, alt: "Shakespeare" },
  { src: homework, alt: "Homework" },
  { src: gullibills, alt: "Gullibills" },
  { src: conversations, alt: "Conversations" },
  { src: healer, alt: "Healer" },
  { src: travel, alt: "Travel to Tomorrow" },
  { src: third, alt: "Third Times a Charm" },
  { src: prego, alt: "Prego" },
  { src: kills, alt: "Kills" },
];
---

<Base title={title}>
  <ThinnerContent>
    <h1 class="font-heading font-bold text-4xl sm:text-5xl my-8">{title}</h1>
    <p class="mb-2 max-w-4xl">
      While at FastPencil I had the opportunity to work with many talented
      authors on their book projects. We&rsquo;d start with a kick-off meeting to go
      over the story and to get a vibe for what they were looking for. Next I&rsquo;d
      start creating some design options and iterating based on feedback until
      we were satisfied. It was truly gratifying to help bring the authors&rsquo;
      creations to life.
    </p>
    <p class="mb-8 font-semibold">
      <a
        href="mailto:mattoleary.design?subject=Hey Matt!"
        class="text-violet-800 hover:text-violet-900 hover:underline"
        >Reach out</a
      > to chat about your next book project!
    </p>

    <div id="gallery" class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
      {books.map((book) => (
        <a
          href={book.src.src}
          data-pswp-width={book.src.width}
          data-pswp-height={book.src.height}
          target="_blank"
          class="block cursor-zoom-in transition-transform duration-300 hover:scale-105"
        >
          <Image src={book.src} alt={book.alt} class="w-full rounded-lg shadow-md" />
        </a>
      ))}
    </div>
  </ThinnerContent>
  <Back next="/work/kiteworks" />
</Base>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/photoswipe@5.4.3/dist/photoswipe.min.css" />


<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  const initLightbox = () => {
    const lightbox = new PhotoSwipeLightbox({
      gallery: '#gallery',
      children: 'a',
      pswpModule: () => import('photoswipe'),
    });
    lightbox.init();
  };

  // Init on page load
  initLightbox();

  // Re-init on Astro page transitions
  document.addEventListener('astro:page-load', initLightbox);
</script>
