---
import Base from "../../layouts/Base.astro";
import ThinnerContent from "../../components/ThinnerContent.astro";
import { Image } from "astro:assets";
import fastpencilcard from "../../assets/fastpencilcard.png";
import Back from "../../components/Back.astro";

const title = "FastPencil — Creative Lead";
---

<Base title={title}>
  <ThinnerContent>
    <section class="mb-8">
      <h1 class="font-heading font-bold text-4xl sm:text-5xl my-8">{title}</h1>
      <Image src={fastpencilcard} alt="FastPencil" class="mb-8 rounded-lg w-full" />

      <p class="mb-6">
        FastPencil was a cloud-based self-publishing platform — authors wrote, formatted, and distributed books in print and e-book form through it, with print-on-demand and distribution to Amazon, Barnes &amp; Noble, and Ingram. As Creative Lead, I designed the web application, the built-in cover-creation tools authors used to produce their covers, and the marketing site.
      </p>

      <p class="mb-6">
        I set the design system for the authoring workspace and cover tools, and built print production standards — trim sizes, bleed, spine width — into the cover templates so files came out press-ready. I also worked on the white-label version of the platform used by other small publishers and enterprises.
      </p>

      <p class="mb-6">
        The role moved between UI design, print production, and marketing creative — collaborating with product and engineering on the authoring tool, and with marketing leadership on campaigns and sales materials.
      </p>
    </section>
    <Back next="/work/books" />
  </ThinnerContent>
</Base>
