---
import Base from "../../layouts/Base.astro";
import ThinnerContent from "../../components/ThinnerContent.astro";
import { Image } from "astro:assets";
import walksantacruz from "../../assets/walksantacruz.png";
import Back from "../../components/Back.astro";

const title = "Walk Santa Cruz";
---

<Base title="Walk Santa Cruz">
  <ThinnerContent>
    <section class="mb-8">
      <h1 class="font-heading font-bold text-4xl sm:text-5xl my-8">{title}</h1>
      <a href="https://walksantacruz.com" target="_blank">
        <Image src={walksantacruz} alt="Walk Santa Cruz" class="mb-8 rounded-lg" />
      </a>
      <p class="mb-6">
        <a
          href="https://walksantacruz.com"
          target="_blank"
          class="text-violet-800 hover:text-violet-900 underline transition-colors"
        >Walk Santa Cruz</a> is a historical walking tour business I founded in 2025. I developed the complete brand identity, website, and all marketing materials from the ground up.
      </p>
      <p class="mb-6">
        The website was built using the Astro framework with Tailwind CSS, featuring FareHarbor booking integration and connections to multiple booking platforms including Airbnb Experiences, GetYourGuide, and Viator/TripAdvisor.
      </p>
      <p class="mb-6">
        My role encompasses all aspects of the business&rsquo;s digital presence: brand development, web design and development, content creation, promotional assets, and ongoing digital marketing and SEO optimization.
      </p>
    </section>
    <Back next="/work/linguid" />
  </ThinnerContent>
</Base>
