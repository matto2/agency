---
import LandingBase from "../layouts/LandingBase.astro";
import Button from "../components/Button.astro";
import { Image } from "astro:assets";
import coffeeShop from "../assets/coffee-shop.jpg";
import jackPhoto from "../assets/jack.webp";

const title = "Websites for Santa Cruz Businesses | Matthew O’Leary";
const description = "A custom Santa Cruz business website, up to 5 pages, with hosting, support, and revisions included.";

// Shared container so every section aligns to the same left/right edges.
const container = "max-w-4xl mx-auto px-6 md:px-8";
const sectionY = "py-16 md:py-20";

const offerItems = [
  "Up to 5 pages total: Home, About, Services, Contact, plus one extra page that fits your business.",
  "Built to be fast, secure, and accessible.",
  "Hosting, updates, and support included.",
  "A few revision rounds included so we can get it right.",
  "Clear communication from start to finish.",
];

const steps = [
  {
    number: "01",
    title: "Quick call or Zoom.",
    body: "We'll talk through your business and what your website needs. If it's easier, I can send over a short Google Form to collect the details instead.",
  },
  {
    number: "02",
    title: "I build the site.",
    body: "I handle the design, layout, copy direction, and setup.",
  },
  {
    number: "03",
    title: "You launch with support.",
    body: "Once the site is live, hosting, updates, and support are already handled.",
  },
];

const faqs = [
  {
    q: "How much does this cost?",
    a: "$99/month on a 12-month term. That covers your site (up to 5 pages), hosting, updates, and support — no large upfront design fee.",
  },
  {
    q: "What if I want out before 12 months?",
    a: "You can buy out the remaining months at 50% of what's left on the term, and the site is yours to keep.",
  },
  {
    q: "Do I own the website?",
    a: "This works like a subscription, similar to your current Wix or Squarespace plan — your site is built, hosted, and maintained as part of the monthly plan for the 12-month term. After that, you're free to cancel anytime at no extra charge: hosting stops, and I hand over your files.",
  },
  {
    q: "Do I need to sign anything? How do I pay?",
    a: "Yes — we'll sign a simple agreement covering the term and scope so everything's clear upfront. Payment is a recurring monthly charge, with no large lump sum due at signing.",
  },
  {
    q: "How long does this take?",
    a: "Most sites go from kickoff to launch in about 2–3 weeks, depending on how quickly I get your content and feedback. I'll give you a firm timeline on our first call.",
  },
  {
    q: "Do we need to meet on Zoom?",
    a: "Not necessarily — a phone call works just as well. If you'd rather skip a live call altogether, I can send over a short Google Form so you can walk me through your business and goals at your own pace.",
  },
  {
    q: "What do I get with this offer?",
    a: "You get a custom website with up to 5 pages: Home, About, Services, Contact, and one additional page suited to your business, such as FAQ, Testimonials, or Gallery. The site is built to be fast, secure, accessible, and easy to maintain, with hosting, support, and a few revision rounds included.",
  },
  {
    q: "What counts as extra?",
    a: "More complex sites, additional pages, custom features, ecommerce, integrations, or major content/copy help are not included in the base offer and will be quoted separately.",
  },
  {
    q: "How many revisions are included?",
    a: "A few revision rounds are included so we can make the site strong without turning the project into endless revisions. If the project grows beyond that scope, additional work is billed separately.",
  },
  {
    q: "Will my site be accessible?",
    a: "I build sites with accessibility in mind so they’re easier for more people to use. That means thoughtful structure, readable design, and a smooth experience on desktop and mobile.",
  },
  {
    q: "Will my site show up on Google?",
    a: "Every site is built with on-page SEO fundamentals — clean structure, fast load times, proper metadata, and mobile-friendliness — so search engines can find and index it. This plan doesn't include ongoing SEO campaigns or paid ad management, but the technical foundation is solid from day one.",
  },
  {
    q: "Can you work with my current website?",
    a: "I don't edit or patch your existing Wix, Squarespace, or WordPress site directly — I build a brand new site from scratch that replaces it, using the same information and content as a starting point. Once your new site is live, you can cancel your old builder's subscription — you won't need it anymore.",
  },
  {
    q: "What if I already have a domain name?",
    a: "Even better. I’ll build the new site on a staging URL so you can review it before anything goes live. Once you approve it, I point your existing domain’s DNS to the new site, and it goes live under the domain you already own — no need to buy a new one or change registrars.",
  },
  {
    q: "Do I need to provide everything?",
    a: "No. If you have photos, copy, or branding, great. If not, I can help fill in the gaps.",
  },
  {
    q: "I don't have good photos — what do I do?",
    a: "That's common, and it won't hold up your launch. We can work with what you have, source stock photography, or I can point you toward a local photographer if you want something custom.",
  },
  {
    q: "What happens after launch?",
    a: "Hosting, updates, and support are included, so you’re not left on your own.",
  },
];
---

<LandingBase title={title} description={description}>
  <!-- HERO -->
  <section class={`pt-10 min-[960px]:pt-16 ${sectionY}`}>
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="flex flex-col min-[960px]:flex-row items-center gap-10 min-[960px]:gap-16">
        <div class="w-full min-[960px]:w-3/5 order-1 min-[960px]:order-2 animate-on-scroll">
          <div class="aspect-square w-full overflow-hidden rounded-2xl shadow-xl">
            <Image
              src={coffeeShop}
              alt="Small business owner working from a local coffee shop"
              class="w-full h-full object-cover"
              widths={[480, 768, 1024]}
              sizes="(min-width: 960px) 60vw, 100vw"
            />
          </div>
        </div>
        <div class="w-full min-[960px]:w-2/5 order-2 min-[960px]:order-1 text-center min-[960px]:text-left">
          <h1 class="font-heading font-bold text-4xl min-[960px]:text-5xl text-stone-900 mb-4 leading-tight animate-on-scroll">
            A better website for your Santa Cruz business.
          </h1>
          <div class="flex items-center justify-center min-[960px]:justify-start gap-3 mb-6 animate-on-scroll">
            <p class="font-heading font-bold text-3xl text-stone-900">
              $99<span class="text-lg font-semibold text-stone-500">/month</span>
            </p>
            <span class="text-xs font-semibold tracking-widest uppercase bg-violet-100 text-violet-800 px-3 py-1.5 rounded-full">
              12-Month Plan
            </span>
          </div>
          <p class="text-lg min-[960px]:text-xl text-stone-600 mb-6 leading-relaxed animate-on-scroll">
            For businesses that don&rsquo;t have a site yet, or already have a Wix, WordPress, or Squarespace site that needs updating but just feels like one more thing on your plate.
          </p>
          <p class="text-lg min-[960px]:text-xl text-stone-600 mb-8 leading-relaxed animate-on-scroll">
            Up to 5 pages, built to be fast, secure, accessible, and ready to convert — with hosting, support, and a straightforward revision process included.
          </p>
          <div class="flex justify-center min-[960px]:justify-start animate-on-scroll">
            <a href="#consultation" class="w-full sm:w-auto">
              <Button text="Get your free consultation" class="w-full" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE OFFER -->
  <section class={sectionY}>
    <div class={container}>
      <div class="text-center">
        <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 animate-on-scroll">
          The Offer
        </p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-3 animate-on-scroll">
          One offer. Clear scope. No surprises.
        </h2>
        <p class="text-lg text-stone-600 mb-12 animate-on-scroll">
          This is a website package for local businesses that want something professional, without a drawn-out process.
        </p>
      </div>

      <div class="bg-white/80 backdrop-blur-sm border border-white/50 rounded-2xl shadow-lg p-8 md:p-10 animate-on-scroll">
        <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-6">
          Included
        </p>

        <ul class="space-y-4 mb-8">
          {offerItems.map((item) => (
            <li class="flex items-start gap-3">
              <svg
                class="w-6 h-6 text-violet-800 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-stone-600">{item}</span>
            </li>
          ))}
        </ul>

        <p class="text-stone-600 border-t border-stone-200 pt-6">
          If you want your website handled and off your plate, this is a solid fit.
        </p>

        <a href="#consultation" class="block mt-8">
          <Button text="Get your free consultation" class="w-full" />
        </a>
      </div>
    </div>
  </section>

  <!-- HAPPY CUSTOMERS -->
  <section class={`${sectionY} bg-stone-100/50`}>
    <div class={container}>
      <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 text-center animate-on-scroll">
        Testimonials
      </p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-12 animate-on-scroll">
        Happy Customers
      </h2>

      <div class="max-w-2xl mx-auto">
        <div class="relative bg-white/80 backdrop-blur-sm border border-white/50 rounded-2xl shadow-lg p-8 md:p-10 animate-on-scroll">
          <svg class="absolute top-6 right-6 w-8 h-8 text-violet-200 rotate-180" fill="currentColor" viewBox="0 0 24 24">
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"></path>
          </svg>

          <p class="text-lg text-stone-700 italic leading-relaxed mb-6">
            &ldquo;Matt did a great job designing my photography website a couple of years ago. He&rsquo;s talented and responsive and I wouldn&rsquo;t hesitate to recommend him.&rdquo;
          </p>

          <div class="flex items-center gap-4">
            <Image
              src={jackPhoto}
              alt="Jack Pitts"
              class="w-14 h-14 rounded-full object-cover ring-2 ring-violet-100 flex-shrink-0"
            />
            <div>
              <p class="font-semibold text-stone-900">&mdash; Jack Pitts</p>
              <a
                href="https://jackpittsphoto.com/"
                target="_blank"
                class="text-sm text-violet-800 hover:text-violet-900 transition-colors"
              >
                https://jackpittsphoto.com/
              </a>
            </div>
          </div>

          <p class="text-sm text-stone-500 border-t border-stone-200 mt-6 pt-6">
            Jack Pitts Photography is a customer on the web design, hosting, and maintenance plan.
          </p>
        </div>

        <p class="text-center text-sm text-stone-500 mt-6 animate-on-scroll">
          Also see:
          <a
            href="https://walksantacruz.com"
            target="_blank"
            class="text-violet-800 hover:text-violet-900 font-medium transition-colors"
          >
            Walk Santa Cruz
          </a>
          — walksantacruz.com
        </p>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" class={`${sectionY} scroll-mt-8`}>
    <div class={container}>
      <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 text-center animate-on-scroll">
        How It Works
      </p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-12 animate-on-scroll">
        No matter where you&rsquo;re starting from, here&rsquo;s how the process goes.
      </h2>

      <div class="space-y-8">
        {steps.map((step) => (
          <div class="flex gap-6 items-start animate-on-scroll">
            <span class="font-heading font-bold text-3xl text-violet-200 flex-shrink-0 w-16">
              {step.number}
            </span>
            <div>
              <h3 class="font-heading font-semibold text-xl mb-1">{step.title}</h3>
              <p class="text-stone-600 leading-relaxed">{step.body}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class={`${sectionY} bg-stone-100/50`}>
    <div class={container}>
      <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 text-center animate-on-scroll">
        FAQ
      </p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-12 animate-on-scroll">
        A Few Questions You Might Have
      </h2>

      <div class="divide-y divide-stone-200">
        {faqs.map((faq) => (
          <div class="py-6 animate-on-scroll">
            <h3 class="font-heading font-semibold text-lg mb-2">{faq.q}</h3>
            <p class="text-stone-600 leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONSULTATION FORM -->
  <section id="consultation" class={`${sectionY} scroll-mt-8`}>
    <div class={container}>
      <div class="text-center">
        <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 animate-on-scroll">
          Get Started
        </p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4 animate-on-scroll">
          Get Your Free Consultation
        </h2>
        <p class="text-lg text-stone-600 mb-10 animate-on-scroll">
          Tell me a bit about your business and I&rsquo;ll follow up to talk through the next step.
        </p>
      </div>

      <div class="max-w-2xl mx-auto animate-on-scroll">
        <form
          name="website consultation"
          method="POST"
          netlify-honeypot="bot-field"
          data-netlify="true"
          class="bg-white p-6 md:p-8 rounded-xl shadow-lg"
        >
          <p class="hidden">
            <label>
              Don&rsquo;t fill this out if you&rsquo;re human: <input name="bot-field" />
            </label>
          </p>

          <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Name</label>
            <input
              type="text"
              name="name"
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus-visible:outline focus-visible:border-violet-800"
              required
            />
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Business Name</label>
            <input
              type="text"
              name="business"
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus-visible:outline focus-visible:border-violet-800"
              required
            />
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Email</label>
            <input
              type="email"
              name="email"
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus-visible:outline focus-visible:border-violet-800"
              required
            />
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Phone</label>
            <input
              type="tel"
              name="phone"
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus-visible:outline focus-visible:border-violet-800"
              required
            />
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Current website (if you have one)</label>
            <input
              type="text"
              name="current_site"
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus-visible:outline focus-visible:border-violet-800"
            />
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Anything else?</label>
            <textarea
              name="message"
              rows="4"
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus-visible:outline focus-visible:border-violet-800 resize-y"
            ></textarea>
          </div>

          <div class="mb-4">
            <button
              type="submit"
              class="w-full rounded-full bg-orange-500 px-8 py-3 text-lg font-semibold text-white shadow-sm hover:bg-orange-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-500"
            >
              Send
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>
</LandingBase>
