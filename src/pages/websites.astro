---
import LandingBase from "../layouts/LandingBase.astro";
import Button from "../components/Button.astro";
import { Image } from "astro:assets";
import coffeeShop from "../assets/coffee-shop.jpg";
import walksantacruz from "../assets/walksantacruz.png";

const title = "Websites for Santa Cruz Businesses | Matthew O’Leary";
const description = "A complete website, hosting, and ongoing updates for $99/month, no tiers to decode.";

// Shared container so every section aligns to the same left/right edges.
const container = "max-w-4xl mx-auto px-6 md:px-8";
const sectionY = "py-16 md:py-20";

const offerItems = [
  "A complete website, up to 5 pages (Home, About, Services, Contact, and one more suited to your business — gallery, FAQ, testimonials, whatever fits)",
  "Hosting, fast and secure",
  "Small updates whenever you need them — new photos, hours, prices, text changes",
  "One person to call or text — not a help ticket",
];

const steps = [
  {
    number: "01",
    title: "Quick call or text about your business.",
    body: "What you do, who you serve, what's not working about your current setup (or the fact that you don't have one yet).",
  },
  {
    number: "02",
    title: "I build your new site.",
    body: "If you've got a Wix, Squarespace, or WordPress site, I rebuild it — same information, none of the bloat, none of the plugins you're afraid to touch. Starting from scratch? I design something clean from the ground up.",
  },
  {
    number: "03",
    title: "You're live, and it's off your plate.",
    body: "Hosting and small updates are covered from here on — you text me, I make the change, usually within 48 hours.",
  },
];

const faqs = [
  {
    q: "What if I want out before 12 months?",
    a: "Reach out and we'll figure out something fair — usually a payout of the remaining months at a reduced rate, or a small buyout fee to hand over your site files outright.",
  },
  {
    q: "What's not included in $99/mo?",
    a: "The base plan covers your site (up to 5 pages), hosting, and small updates. Online booking, e-commerce, extra pages beyond 5, or a full redesign are quoted separately — you'll always know the price before I start.",
  },
  {
    q: "Do I need to learn anything to update my site?",
    a: "No. Text or email me what you want changed, and I make the update — usually within 48 hours.",
  },
  {
    q: "What do I actually get for hosting?",
    a: "A fast, secure site with no downtime worries — I handle the technical side entirely, so you don't have to think about it.",
  },
];
---

<LandingBase title={title} description={description}>
  <!-- HERO -->
  <section class={`pt-10 min-[960px]:pt-16 ${sectionY}`}>
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="flex flex-col min-[960px]:flex-row items-center gap-10 min-[960px]:gap-16">
        <div class="w-full min-[960px]:w-3/5 order-1 min-[960px]:order-2 animate-on-scroll">
          <div class="aspect-square w-full overflow-hidden rounded-2xl shadow-xl">
            <Image
              src={coffeeShop}
              alt="Small business owner working from a local coffee shop"
              class="w-full h-full object-cover"
              widths={[480, 768, 1024]}
              sizes="(min-width: 960px) 60vw, 100vw"
            />
          </div>
        </div>
        <div class="w-full min-[960px]:w-2/5 order-2 min-[960px]:order-1 text-center min-[960px]:text-left">
          <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 animate-on-scroll">
            Websites for Santa Cruz Businesses
          </p>
          <h1 class="font-heading font-bold text-4xl min-[960px]:text-5xl text-stone-900 mb-6 leading-tight animate-on-scroll">
            Your website, built brand new or refreshed —<br />for one flat price
          </h1>
          <p class="text-lg min-[960px]:text-xl text-stone-600 mb-8 leading-relaxed animate-on-scroll">
            Got a Wix or Squarespace site you&rsquo;ve been avoiding? Or nothing but a Facebook page? Either way — I&rsquo;ll build (or rebuild) something clean and simple, then take care of it for you.
          </p>
          <div class="flex justify-center min-[960px]:justify-start animate-on-scroll">
            <a href="#consultation" class="w-full sm:w-auto">
              <Button text="Get your free consultation" class="w-full" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- THE OFFER -->
  <section class={sectionY}>
    <div class={container}>
      <div class="text-center">
        <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 animate-on-scroll">
          The Offer
        </p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-3 animate-on-scroll">
          One offer. No surprises.
        </h2>
        <p class="text-lg text-stone-600 mb-12 animate-on-scroll">
          This is the whole thing — no tiers to decode.
        </p>
      </div>

      <div class="bg-white/80 backdrop-blur-sm border border-white/50 rounded-2xl shadow-lg p-8 md:p-10 animate-on-scroll">
        <div class="flex flex-wrap items-baseline justify-between gap-3 mb-6">
          <p class="font-heading font-bold text-4xl md:text-5xl">
            $99<span class="text-xl md:text-2xl font-semibold text-stone-500">/month</span>
          </p>
          <span class="text-xs font-semibold tracking-widest uppercase bg-violet-100 text-violet-800 px-3 py-1.5 rounded-full">
            12-Month Term
          </span>
        </div>

        <ul class="space-y-4 mb-8">
          {offerItems.map((item) => (
            <li class="flex items-start gap-3">
              <svg
                class="w-6 h-6 text-violet-800 flex-shrink-0 mt-0.5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              <span class="text-stone-600">{item}</span>
            </li>
          ))}
        </ul>

        <p class="text-stone-600 border-t border-stone-200 pt-6">
          Want more — online booking, e-commerce, a bigger redesign? I&rsquo;ll quote that separately. The $99/mo base always covers your site, hosting, and upkeep.
        </p>

        <a href="#consultation" class="block mt-8">
          <Button text="Get your free consultation" class="w-full" />
        </a>
      </div>
    </div>
  </section>

  <!-- CASE STUDY -->
  <section class={`${sectionY} bg-stone-100/50`}>
    <div class={container}>
      <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 text-center animate-on-scroll">
        Case Study
      </p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-12 animate-on-scroll">
        Walk Santa Cruz
      </h2>

      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12 animate-on-scroll">
        <a href="https://walksantacruz.com" target="_blank" class="w-full md:w-1/2 flex-shrink-0">
          <Image
            src={walksantacruz}
            alt="Walk Santa Cruz website"
            class="rounded-xl shadow-lg w-full"
          />
        </a>
        <div class="w-full md:w-1/2">
          <p class="text-lg text-stone-600 mb-6 leading-relaxed">
            I run my own tour business on a site built exactly this way — fast-loading, hand-coded, no bloat. If you&rsquo;ve ever waited on a slow Wix or Squarespace site to load on your phone, this is the alternative.
          </p>
          <a
            href="https://walksantacruz.com"
            target="_blank"
            class="inline-flex items-center gap-1 text-violet-800 hover:text-violet-900 font-semibold transition-colors"
          >
            walksantacruz.com
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how-it-works" class={`${sectionY} scroll-mt-8`}>
    <div class={container}>
      <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 text-center animate-on-scroll">
        How It Works
      </p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-4 animate-on-scroll">
        No matter where you&rsquo;re starting from
      </h2>
      <p class="text-lg text-stone-600 text-center mb-12 animate-on-scroll">
        A site you already dread logging into, or nothing yet at all — either way, here&rsquo;s how it goes.
      </p>

      <div class="space-y-8 mb-12">
        {steps.map((step) => (
          <div class="flex gap-6 items-start animate-on-scroll">
            <span class="font-heading font-bold text-3xl text-violet-200 flex-shrink-0 w-16">
              {step.number}
            </span>
            <div>
              <h3 class="font-heading font-semibold text-xl mb-1">{step.title}</h3>
              <p class="text-stone-600 leading-relaxed">{step.body}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="bg-violet-50 border-l-4 border-violet-800 rounded-r-lg p-6 animate-on-scroll">
        <p class="text-stone-700 leading-relaxed">
          <span class="font-semibold">Already have a site you&rsquo;re scared to touch?</span> That&rsquo;s normal — and it&rsquo;s exactly the kind of mess I take off your hands. I rebuild it clean, and you never have to log into a website builder again.
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class={`${sectionY} bg-stone-100/50`}>
    <div class={container}>
      <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 text-center animate-on-scroll">
        FAQ
      </p>
      <h2 class="font-heading text-3xl md:text-4xl font-bold text-center mb-12 animate-on-scroll">
        A Few Questions You Might Have
      </h2>

      <div class="divide-y divide-stone-200">
        {faqs.map((faq) => (
          <div class="py-6 animate-on-scroll">
            <h3 class="font-heading font-semibold text-lg mb-2">{faq.q}</h3>
            <p class="text-stone-600 leading-relaxed">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CONSULTATION FORM -->
  <section id="consultation" class={`${sectionY} scroll-mt-8`}>
    <div class={container}>
      <div class="text-center">
        <p class="text-sm font-semibold tracking-widest uppercase text-violet-800 mb-4 animate-on-scroll">
          Get Started
        </p>
        <h2 class="font-heading text-3xl md:text-4xl font-bold mb-4 animate-on-scroll">
          Get My Free Consultation
        </h2>
        <p class="text-lg text-stone-600 mb-10 animate-on-scroll">
          Tell me a bit about your business and I&rsquo;ll follow up to talk it through — no pressure, no obligation.
        </p>
      </div>

      <div class="max-w-2xl mx-auto animate-on-scroll">
        <form
          name="website consultation"
          method="POST"
          netlify-honeypot="bot-field"
          data-netlify="true"
          class="bg-white p-6 md:p-8 rounded-xl shadow-lg"
        >
          <p class="hidden">
            <label>
              Don&rsquo;t fill this out if you&rsquo;re human: <input name="bot-field" />
            </label>
          </p>

          <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Name</label>
            <input
              type="text"
              name="name"
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus-visible:outline focus-visible:border-violet-800"
              required
            />
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Business Name</label>
            <input
              type="text"
              name="business"
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus-visible:outline focus-visible:border-violet-800"
              required
            />
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Email</label>
            <input
              type="email"
              name="email"
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus-visible:outline focus-visible:border-violet-800"
              required
            />
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Phone</label>
            <input
              type="tel"
              name="phone"
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus-visible:outline focus-visible:border-violet-800"
              required
            />
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Current website (if you have one)</label>
            <input
              type="text"
              name="current_site"
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus-visible:outline focus-visible:border-violet-800"
            />
          </div>

          <div class="mb-4">
            <label class="block text-gray-700 font-bold mb-2">Anything else?</label>
            <textarea
              name="message"
              rows="4"
              class="shadow appearance-none border rounded w-full py-2 px-3 text-gray-700 leading-tight focus-visible:outline focus-visible:border-violet-800 resize-y"
            ></textarea>
          </div>

          <div class="mb-4">
            <button
              type="submit"
              class="w-full rounded-full bg-orange-500 px-8 py-3 text-lg font-semibold text-white shadow-sm hover:bg-orange-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-orange-500"
            >
              Send
            </button>
          </div>
        </form>
      </div>
    </div>
  </section>
</LandingBase>
