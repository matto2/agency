---
const { quote, img, alt, person, title, company } = Astro.props;
import { Image } from "astro:assets";
---

<div class="relative bg-white/70 backdrop-blur-sm border border-white/50 p-8 rounded-xl mb-6 shadow-md hover:shadow-lg transition-shadow animate-on-scroll">
  <svg class="absolute top-4 right-4 w-8 h-8 text-violet-200 rotate-180" fill="currentColor" viewBox="0 0 24 24">
    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
  </svg>
  <p class="mb-6 text-gray-600 text-lg italic leading-relaxed">{quote}</p>
  <div class="flex items-center">
    <Image
      src={img}
      alt={alt}
      width={200}
      class="mr-4 rounded-full w-12 h-12 object-cover ring-2 ring-violet-100"
      quality={100}
    />
    <div>
      <p class="font-bold text-gray-800">{person}</p>
      <p class="text-sm text-gray-500">
        {title}, {company}
      </p>
    </div>
  </div>
</div>
